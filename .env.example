# =============================================================================
# Budgetman — variables para docker compose (copiar a .env)
#   copy .env.example .env (Windows)
# =============================================================================

# --- Instalación nueva en Synology / NAS -------------------------------------
# Deja comentado EXISTING_DB_VOLUME. Docker creará un volumen nuevo del proyecto.
# Solo si migras datos desde budget-manager local, usa docker-compose.existing-db.yml

# EXISTING_DB_VOLUME=budget-manager_db_data

# --- Red / acceso web --------------------------------------------------------
WEB_PORT=48080
APP_BASE_URL=http://TU-IP-NAS:48080

# --- Base de datos MySQL (contenedor db) -------------------------------------
# En instalación nueva, define contraseñas seguras ANTES del primer arranque.
MYSQL_DATABASE=budget_manager
MYSQL_USER=budget
MYSQL_PASSWORD=cambia_esta_contraseña
MYSQL_ROOT_PASSWORD=cambia_root_tambien

# --- API PHP -----------------------------------------------------------------
COOKIE_SECURE=0
ALLOW_BOOTSTRAP=1

# --- Desarrollo frontend (Vite) ----------------------------------------------
VITE_DEV_API_PROXY=http://127.0.0.1:48080
