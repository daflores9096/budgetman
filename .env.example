# =============================================================================
# Budgetman — variables para docker compose (copiar a .env)
#   copy .env.example .env (Windows)
# =============================================================================

# --- Reutilizar base de datos existente de budget-manager --------------------
# Volumen Docker con los datos actuales. NO usar `docker compose down -v`.
# Antes de levantar budgetman, detén el stack de budget-manager para evitar
# dos contenedores MySQL escribiendo sobre el mismo volumen.
EXISTING_DB_VOLUME=budget-manager_db_data

# --- Red / acceso web --------------------------------------------------------
WEB_PORT=48080
APP_BASE_URL=http://localhost:48080

# --- Base de datos MySQL (contenedor db) -------------------------------------
# Deben coincidir con las credenciales con las que se creó el volumen existente.
# Copia los valores desde el .env de budget-manager si reutilizas su volumen.
MYSQL_DATABASE=budget_manager
MYSQL_USER=budget
MYSQL_PASSWORD=your_existing_password
MYSQL_ROOT_PASSWORD=your_existing_root_password

# --- API PHP -----------------------------------------------------------------
COOKIE_SECURE=0
ALLOW_BOOTSTRAP=1

# --- Desarrollo frontend (Vite) ----------------------------------------------
VITE_DEV_API_PROXY=http://127.0.0.1:48080
